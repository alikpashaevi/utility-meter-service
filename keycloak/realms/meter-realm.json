{
  "realm": "meter-realm",
  "enabled": true,
  "displayName": "Meter Service Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "meter-service-client",
      "enabled": true,
      "publicClient": false,
      "secret": "meter-service-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8180/*"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard household user — can manage own meters and readings"
      },
      {
        "name": "ADMIN",
        "description": "Utility company admin — can view all users' meters and readings"
      }
    ]
  },
  "users": [
    {
      "username": "testuser",
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "adminuser",
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "adminpass",
          "temporary": false
        }
      ],
      "realmRoles": ["USER", "ADMIN"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "displayName": "Google",
      "config": {
        "clientId": "YOUR_GOOGLE_CLIENT_ID",
        "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
        "syncMode": "IMPORT"
      }
    }
  ]
}
